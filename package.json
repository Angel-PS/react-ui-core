{
  "name": "@react/ui-core",
  "version": "0.1.1",
  "description": "Librería de componentes React reutilizables",
  "author": "Angel",
  "license": "MIT",
  "main": "./dist/ui-core.cjs.js",
  "module": "./dist/ui-core.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/ui-core.es.js",
      "require": "./dist/ui-core.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "build:watch": "vite build --watch",
    "lint": "eslint src --ext ts,tsx",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.3.0"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "library"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "dependencies": {
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0"
  }
}
